{
  "server": {
    "baseUrl": "",
    "port": 5003
  },
  "max_attempts": 3,
  "ms_client_request_timeout": 600001,
  "mcp": {
    "servers": {
      "test": {
        "command": "node",
        "args": ["./mcp-servers/test-server.mjs"],
        "env": {}
      }
    },
    "tools": {
      "echo": {
        "server": "test",
        "tool": "echo"
      },
      "calc": {
        "server": "test",
        "tool": "calculator"
      }
    }
  },
  "models": {
    "my-unittest-model": {
        "api": "OpenAI_Azure",
        "api_key": "${AZURE_OPENAI_API_KEY}",
        "model_type": "chat",

         "endpoint": "https://mmigh-m8gpxf72-eastus2.cognitiveservices.azure.com",
         "deployment": "o3",
         "api_version": "2024-12-01-preview",

        "reasoning_effort": "low",
        "context_size": 128000,
        "output_limit": 16384
    },
    "my-unittest-with-mcp-model": {
        "api": "OpenAI_Azure",
        "api_key": "${AZURE_OPENAI_API_KEY}",
        "model_type": "chat",

         "endpoint": "https://mmigh-m8gpxf72-eastus2.cognitiveservices.azure.com",
         "deployment": "o3",
         "api_version": "2024-12-01-preview",

        "reasoning_effort": "low",
        "context_size": 128000,
        "output_limit": 16384,
        "tools": ["echo"]
    },
    "my-unittest-emodel": {
      "api": "OpenAI_Azure",
      "api_key": "${AZURE_OPENAI_API_KEY}",
      "model_type": "chat",

      "comment": "TODO: model was: text-embedding-3-small",
      "endpoint": "https://mmigh-m8gpxf72-eastus2.cognitiveservices.azure.com",
      "deployment": "text-embedding-3-large",
      "api_version": "2024-12-01-preview",

      "temperature": 0.8,
      "context_size": 8192,
      "output_limit": 2048
    },
    "test-policy-conversion-image-page-loopback": {
      "api": "TestPolicy",
      "model_type": "chat",
      "test_policy_response_mode": "conversion/image",
      "test_policy_markdown_from_image": true,
      "test_policy_markdown_prefix": "transcribed:",
      "test_policy_error_if_image_includes": "mock-page-2.png",
      "test_policy_error": {
        "provider": "openai",
        "message": "image blocked by content safety",
        "interpretedErrorType": "content_filter_violation",
        "interpretedCode": 422,
        "interpretedMessage": "Content was filtered due to policy violations."
      }
    }
  }
}
